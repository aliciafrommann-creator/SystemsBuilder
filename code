### `store/model-store.ts`

```ts
'use client'

import { create } from 'zustand'
import { persist } from 'zustand/middleware'
import { nanoid } from 'nanoid'
import {
  Relationship,
  SystemVariable,
  VariableKind,
  Intervention,
} from '@/types/system'
import { sampleRelationships, sampleVariables } from '@/lib/sample-data'
import { qualifyVariable } from '@/lib/variable-check'
import { detectLoops } from '@/lib/loop-detection'

interface ModelStore {
  variables: SystemVariable[]
  relationships: Relationship[]
  interventions: Intervention[]
  selectedVariableId?: string
  selectedRelationshipId?: string

  addVariable: (label: string, kind?: VariableKind) => void
  updateVariable: (id: string, updates: Partial<SystemVariable>) => void
  updateVariablePosition: (id: string, x: number, y: number) => void
  deleteVariable: (id: string) => void
  selectVariable: (id?: string) => void

  addRelationship: (sourceId: string, targetId: string, polarity: '+' | '-') => void
  updateRelationship: (id: string, updates: Partial<Relationship>) => void
  deleteRelationship: (id: string) => void
  selectRelationship: (id?: string) => void

  addIntervention: (title: string) => void
  updateIntervention: (id: string, updates: Partial<Intervention>) => void

  clearSelection: () => void
  getLoops: () => ReturnType<typeof detectLoops>
}

export const useModelStore = create<ModelStore>()(
  persist(
    (set, get) => ({
      variables: sampleVariables,
      relationships: sampleRelationships,
      interventions: [],
      selectedVariableId: undefined,
      selectedRelationshipId: undefined,

      addVariable: (label, kind = 'variable') => {
        const result = qualifyVariable(label)
        const count = get().variables.length

        const base: SystemVariable = {
          id: nanoid(),
          label,
          kind,
          quality: result.quality,
          notes: result.reason,
          icebergLevel: kind === 'mental_model' ? 'mental_model' : 'structure',
          x: 120 + (count % 4) * 200,
          y: 120 + Math.floor(count / 4) * 140,
          indicator: '',
          unit: '',
        }

        const variable: SystemVariable =
          kind === 'stock'
            ? {
                ...base,
                accumulation: true,
                initialValue: 0,
                currentValue: 0,
                inflowIds: [],
                outflowIds: [],
              }
            : kind === 'flow'
            ? {
                ...base,
                formula: '',
              }
            : base

        set((state) => ({
          variables: [...state.variables, variable],
        }))
      },

      updateVariable: (id, updates) => {
        set((state) => ({
          variables: state.variables.map((v) => (v.id === id ? { ...v, ...updates } : v)),
        }))
      },

      updateVariablePosition: (id, x, y) => {
        set((state) => ({
          variables: state.variables.map((v) => (v.id === id ? { ...v, x, y } : v)),
        }))
      },

      deleteVariable: (id) => {
        set((state) => ({
          variables: state.variables.filter((v) => v.id !== id),
          relationships: state.relationships.filter((r) => r.sourceId !== id && r.targetId !== id),
          selectedVariableId: state.selectedVariableId === id ? undefined : state.selectedVariableId,
        }))
      },

      selectVariable: (id) => set({ selectedVariableId: id, selectedRelationshipId: undefined }),

      addRelationship: (sourceId, targetId, polarity) => {
        const rel: Relationship = {
          id: nanoid(),
          sourceId,
          targetId,
          polarity,
          delay: false,
          delayType: 'none',
          rationale: '',
          evidenceLevel: 'assumed',
          confidence: 0.5,
          isDirect: true,
        }

        set((state) => {
          const nextRelationships = [...state.relationships, rel]
          const nextVariables = state.variables.map((v) => {
            if (v.kind === 'stock' && v.id === targetId) {
              return { ...v, inflowIds: [...(v.inflowIds ?? []), rel.id] }
            }
            if (v.kind === 'stock' && v.id === sourceId) {
              return { ...v, outflowIds: [...(v.outflowIds ?? []), rel.id] }
            }
            return v
          })

          return {
            relationships: nextRelationships,
            variables: nextVariables,
          }
        })
      },

      updateRelationship: (id, updates) => {
        set((state) => ({
          relationships: state.relationships.map((r) => (r.id === id ? { ...r, ...updates } : r)),
        }))
      },

      deleteRelationship: (id) => {
        set((state) => ({
          relationships: state.relationships.filter((r) => r.id !== id),
          variables: state.variables.map((v) => ({
            ...v,
            inflowIds: v.inflowIds?.filter((relId) => relId !== id),
            outflowIds: v.outflowIds?.filter((relId) => relId !== id),
          })),
          selectedRelationshipId: state.selectedRelationshipId === id ? undefined : state.selectedRelationshipId,
        }))
      },

      selectRelationship: (id) => set({ selectedRelationshipId: id, selectedVariableId: undefined }),

      addIntervention: (title) => {
        const intervention: Intervention = {
          id: nanoid(),
          title,
          targetVariableIds: [],
          level: 'structure',
          intendedEffect: '',
          possibleSideEffects: [],
        }

        set((state) => ({ interventions: [...state.interventions, intervention] }))
      },

      updateIntervention: (id, updates) => {
        set((state) => ({
          interventions: state.interventions.map((i) => (i.id === id ? { ...i, ...updates } : i)),
        }))
      },

      clearSelection: () => set({ selectedVariableId: undefined, selectedRelationshipId: undefined }),

      getLoops: () => detectLoops(get().variables, get().relationships),
    }),
    {
      name: 'systems-thinking-model',
    }
  )
)
```

