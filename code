  // stock / flow support
  accumulation?: boolean
  initialValue?: number
  currentValue?: number
  formula?: string
  sourceId?: string
  targetId?: string
  inflowIds?: string[]
  outflowIds?: string[]
}

export interface Relationship {
  id: string
  sourceId: string
  targetId: string
  polarity: Polarity
  delay?: boolean
  delayType?: DelayType
  rationale?: string
  evidenceLevel?: EvidenceLevel
  confidence?: number
  isDirect?: boolean
  possibleIntermediateVariable?: string
}

