### `lib/simulation.ts`

```ts
import { Relationship, SystemVariable } from '@/types/system'

export interface SimulationInput {
  variables: SystemVariable[]
  relationships: Relationship[]
  interventionVariableId?: string
  interventionDelta?: number
}

export interface SimulationResult {
  steps: Array<Record<string, number>>
  warnings: string[]
}

// Deliberately simple placeholder.
// Real system dynamics simulation should come later.
export function runSimpleSimulation(input: SimulationInput, stepsCount = 5): SimulationResult {
  const warnings: string[] = [
    'This is a simplified directional simulation, not a full system dynamics engine.',
  ]

  const numericVariables = input.variables.filter((v) => typeof v.currentValue === 'number')
  const state: Record<string, number> = {}

  for (const variable of numericVariables) {
    state[variable.id] = variable.currentValue ?? variable.initialValue ?? 0
  }

  const steps: Array<Record<string, number>> = [{ ...state }]

  for (let i = 0; i < stepsCount; i += 1) {
    const next = { ...state }

    for (const rel of input.relationships) {
      if (!(rel.sourceId in state) || !(rel.targetId in state)) continue
      const delta = state[rel.sourceId] * 0.05
      next[rel.targetId] += rel.polarity === '+' ? delta : -delta
    }

    if (input.interventionVariableId && input.interventionVariableId in next) {
      next[input.interventionVariableId] += input.interventionDelta ?? 0
    }

    Object.assign(state, next)
    steps.push({ ...state })
  }

  return { steps, warnings }
}
```

