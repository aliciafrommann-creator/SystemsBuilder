      return { border: '1px solid #52525b', borderRadius: 999, background: '#f4f4f5' }
    case 'source_sink':
    case 'cloud':
      return { border: '1px solid #d4d4d8', borderRadius: 999, background: '#fafafa' }
    default:
      return { border: '1px solid #d4d4d8', borderRadius: 12, background: '#ffffff' }
  }
}

function getEdgeLabel(type?: string, polarity?: string, delayType?: string) {
  if (type === 'causal_link') {
    return `${polarity ?? ''}${delayType && delayType !== 'none' ? ` · ${delayType}` : ''}`
  }
  if (type === 'information_link') return 'info'
  if (type === 'flow_pipe') return 'flow'
  return ''
}

function getEdgeStyle(type?: string) {
  if (type === 'information_link') {
    return { strokeDasharray: '5 4' }
  }
  if (type === 'flow_pipe') {
    return { strokeWidth: 2.5 }
  }
  return {}
}

export function AppCanvas() {
  const variables = useModelStore((s) => s.variables)
  const relationships = useModelStore((s) => s.relationships)
  const selectVariable = useModelStore((s) => s.selectVariable)
  const selectRelationship = useModelStore((s) => s.selectRelationship)
  const addRelationship = useModelStore((s) => s.addRelationship)
  const updateVariablePosition = useModelStore((s) => s.updateVariablePosition)

  const initialNodes = useMemo<Node[]>(
    () =>
      variables.map((v) => ({
        id: v.id,
        position: { x: v.x, y: v.y },
        data: { label: `${v.label}${v.unit ? ` (${v.unit})` : ''}` },
        style: {
          ...getNodeStyle(v.kind),
          padding: 12,
          width: 190,
          fontSize: 13,
        },
      })),
    [variables]
  )

  const initialEdges = useMemo<Edge[]>(
    () =>
      relationships.map((r) => ({
        id: r.id,
        source: r.sourceId,
        target: r.targetId,
        label: getEdgeLabel(r.type, r.polarity, r.delayType),
        style: getEdgeStyle(r.type),
        markerEnd: {
          type: MarkerType.ArrowClosed,
        },
      })),
    [relationships]
  )

  const [nodes, setNodes, onNodesChange] = useNodesState(initialNodes)
  const [edges, setEdges, onEdgesChange] = useEdgesState(initialEdges)

  useEffect(() => setNodes(initialNodes), [initialNodes, setNodes])
  useEffect(() => setEdges(initialEdges), [initialEdges, setEdges])

  const onConnect: OnConnect = (params: Edge | Connection) => {
    if (!params.source || !params.target) return
    addRelationship(params.source, params.target, 'causal_link', '+')
  }

  return (
    <div className="h-full w-full">
      <ReactFlow
        nodes={nodes}
        edges={edges}
        onNodesChange={onNodesChange}
        onEdgesChange={onEdgesChange}
        onConnect={onConnect}
        onNodeClick={(_, node) => selectVariable(node.id)}
        onEdgeClick={(_, edge) => selectRelationship(edge.id)}
        onPaneClick={() => {
          selectVariable(undefined)
          selectRelationship(undefined)
        }}
        onNodeDragStop={(_, node) => updateVariablePosition(node.id, node.position.x, node.position.y)}
        fitView
      >
        <Background />
        <Controls />
      </ReactFlow>
    </div>
  )
}
