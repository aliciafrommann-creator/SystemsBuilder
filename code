export type LoopType = 'R' | 'B' | 'unknown'
export type VariableKind = 'variable' | 'stock' | 'flow' | 'auxiliary' | 'mental_model' | 'source_sink'
export type DelayType = 'none' | 'short' | 'medium' | 'long' | 'custom'
export type EvidenceLevel = 'observed' | 'assumed' | 'weak_signal'
export type InterventionLevel = 'parameter' | 'feedback' | 'information_flow' | 'rules' | 'structure' | 'goal' | 'mental_model'

export interface SystemVariable {
  id: string
  label: string
  kind: VariableKind
  description?: string
  indicator?: string
  unit?: string
  icebergLevel?: IcebergLevel
  quality: VariableQuality
  notes?: string
  x: number
