import { LeveragePointCandidate, SystemVariable } from '@/types/system'

export function getLeveragePointCandidates(variables: SystemVariable[]): LeveragePointCandidate[] {
  return variables
    .filter((v) => v.icebergLevel === 'structure' || v.icebergLevel === 'mental_model')
    .map((v) => ({
      variableId: v.id,
      level: v.icebergLevel === 'mental_model' ? 'mental_model' : 'structure',
      reason:
        v.icebergLevel === 'mental_model'
          ? 'Mental models often influence multiple downstream structures and decisions.'
          : 'Structural variables often affect multiple visible patterns and events.',
      score: v.icebergLevel === 'mental_model' ? 0.9 : 0.75,
    }))
}
