'use client'

import { FormEvent, useState } from 'react'
import { useModelStore } from '@/store/model-store'
import { VariableKind } from '@/types/system'

const variableKinds: { value: VariableKind; label: string }[] = [
  { value: 'variable', label: 'Variable' },
  { value: 'stock', label: 'Stock' },
  { value: 'flow', label: 'Flow' },
  { value: 'auxiliary', label: 'Auxiliary' },
  { value: 'mental_model', label: 'Mental model' },
  { value: 'source_sink', label: 'Source / Sink' },
]

export function Toolbar() {
  const [label, setLabel] = useState('')
  const [kind, setKind] = useState<VariableKind>('variable')
  const addVariable = useModelStore((s) => s.addVariable)

  function onSubmit(e: FormEvent) {
    e.preventDefault()
    if (!label.trim()) return
    addVariable(label.trim(), kind)
    setLabel('')
  }

  return (
    <div className="border-b border-zinc-200 bg-white px-4 py-3">
      <form onSubmit={onSubmit} className="flex gap-2">
        <input
          value={label}
          onChange={(e) => setLabel(e.target.value)}
          placeholder="Add variable, stock, flow, or mental model"
          className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm outline-none focus:border-black"
        />
        <select
          value={kind}
          onChange={(e) => setKind(e.target.value as VariableKind)}
          className="rounded-md border border-zinc-300 px-3 py-2 text-sm"
        >
          {variableKinds.map((option) => (
            <option key={option.value} value={option.value}>
              {option.label}
            </option>
          ))}
        </select>
        <button className="rounded-md bg-black px-4 py-2 text-sm text-white">Add</button>
      </form>
    </div>
  )
}
