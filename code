### `lib/loop-detection.ts` (patched)

```ts
import { Loop, LoopType, Relationship } from '@/types/system'
import type { SystemVariable } from '@/types/system'

function buildAdjacency(relationships: Relationship[]): Map<string, Relationship[]> {
  const map = new Map<string, Relationship[]>()

  for (const rel of relationships) {
    if (rel.type !== 'causal_link') continue

    const existing = map.get(rel.sourceId) ?? []
    existing.push(rel)
    map.set(rel.sourceId, existing)
  }

  return map
}

function classifyLoop(relationships: Relationship[]): LoopType {
  const negativeCount = relationships.filter((r) => r.polarity === '-').length
  return negativeCount % 2 === 0 ? 'R' : 'B'
}

function isCLDRelevantNode(variable?: SystemVariable) {
  if (!variable) return false
  return variable.kind === 'variable' || variable.kind === 'mental_model' || variable.kind === 'auxiliary'
}

export function detectLoops(variables: SystemVariable[], relationships: Relationship[]): Loop[] {
  const variableMap = new Map(variables.map((v) => [v.id, v]))
  const adjacency = buildAdjacency(relationships)
  const loops: Loop[] = []
  const seen = new Set<string>()

  function dfs(startId: string, currentId: string, pathVars: string[], pathRels: Relationship[]) {
    const outgoing = adjacency.get(currentId) ?? []

    for (const rel of outgoing) {
      const target = variableMap.get(rel.targetId)
      if (!isCLDRelevantNode(target)) continue

      if (rel.targetId === startId && pathVars.length >= 2) {
        const variableIds = [...pathVars, startId]
        const relationshipIds = [...pathRels, rel].map((r) => r.id)
        const key = [...relationshipIds].sort().join('|')

        if (!seen.has(key)) {
          seen.add(key)
          loops.push({
            id: `loop-${loops.length + 1}`,
            variableIds,
            relationshipIds,
            type: classifyLoop([...pathRels, rel]),
          })
        }

        continue
      }

      if (pathVars.includes(rel.targetId)) continue
      dfs(startId, rel.targetId, [...pathVars, rel.targetId], [...pathRels, rel])
    }
  }

  for (const variable of variables) {
    if (!isCLDRelevantNode(variable)) continue
    dfs(variable.id, variable.id, [variable.id], [])
  }

  return loops
}
```

### `lib/relationship-check.ts` (patched)

```ts
import { Relationship, SystemVariable } from '@/types/system'

export function evaluateRelationship(
  relationship: Relationship,
  variables: SystemVariable[]
): { status: 'good' | 'needs_refinement'; messages: string[] } {
  const source = variables.find((v) => v.id === relationship.sourceId)
  const target = variables.find((v) => v.id === relationship.targetId)
  const messages: string[] = []

  if (!source || !target) {
    return { status: 'needs_refinement', messages: ['Source or target variable is missing.'] }
  }

  if (relationship.type === 'causal_link') {
    if (!relationship.polarity) {
      messages.push('Causal links need a polarity (+ or -).')
    }
    if (!relationship.rationale) {
      messages.push('Add a rationale: if the source changes, what happens to the target and why?')
    }
    if (!relationship.isDirect) {
      messages.push('This may be an indirect relationship. Consider adding an intermediate variable.')
    }
  }

  if (relationship.type === 'information_link') {
    if (!(target.kind === 'flow' || target.kind === 'auxiliary')) {
      messages.push('Information links should usually point to a flow or auxiliary.')
    }
  }

  if (relationship.type === 'flow_pipe') {
    const validSource = source.kind === 'stock' || source.kind === 'cloud' || source.kind === 'source_sink'
    const validTarget = target.kind === 'stock' || target.kind === 'cloud' || target.kind === 'source_sink'

    if (!validSource || !validTarget) {
      messages.push('Flow pipes must connect stock/cloud endpoints.')
    }
  }

  return {
    status: messages.length === 0 ? 'good' : 'needs_refinement',
    messages,
  }
}
