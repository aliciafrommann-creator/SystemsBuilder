### `components/app-canvas.tsx`

```tsx
'use client'

import { useEffect, useMemo } from 'react'
import ReactFlow, {
  Background,
  Controls,
  Edge,
  MarkerType,
  Node,
  OnConnect,
  Connection,
  useEdgesState,
  useNodesState,
} from 'reactflow'
import 'reactflow/dist/style.css'
import { useModelStore } from '@/store/model-store'

function getNodeStyle(kind: string) {
  switch (kind) {
    case 'stock':
      return {
        border: '2px solid #111827',
        borderRadius: 4,
        background: '#ffffff',
      }
    case 'flow':
      return {
        border: '1px dashed #111827',
        borderRadius: 999,
        background: '#fafafa',
      }
    case 'auxiliary':
      return {
        border: '1px solid #3f3f46',
        borderRadius: 999,
        background: '#ffffff',
      }
    case 'mental_model':
      return {
        border: '1px solid #52525b',
        borderRadius: 999,
        background: '#f4f4f5',
      }
    case 'source_sink':
      return {
        border: '1px solid #d4d4d8',
        borderRadius: 999,
        background: '#fafafa',
      }
    default:
      return {
        border: '1px solid #d4d4d8',
        borderRadius: 12,
        background: '#ffffff',
      }
  }
}

export function AppCanvas() {
  const variables = useModelStore((s) => s.variables)
  const relationships = useModelStore((s) => s.relationships)
  const selectVariable = useModelStore((s) => s.selectVariable)
  const selectRelationship = useModelStore((s) => s.selectRelationship)
  const addRelationship = useModelStore((s) => s.addRelationship)
  const updateVariablePosition = useModelStore((s) => s.updateVariablePosition)

  const initialNodes = useMemo<Node[]>(
    () =>
      variables.map((v) => ({
        id: v.id,
        position: { x: v.x, y: v.y },
        data: {
          label: `${v.label}${v.unit ? ` (${v.unit})` : ''}`,
        },
        style: {
          ...getNodeStyle(v.kind),
          padding: 12,
          width: 190,
          fontSize: 13,
        },
      })),
    [variables]
  )

  const initialEdges = useMemo<Edge[]>(
    () =>
      relationships.map((r) => ({
        id: r.id,
        source: r.sourceId,
        target: r.targetId,
        label: `${r.polarity}${r.delayType && r.delayType !== 'none' ? ` · ${r.delayType}` : ''}`,
        markerEnd: {
          type: MarkerType.ArrowClosed,
        },
      })),
    [relationships]
  )

  const [nodes, setNodes, onNodesChange] = useNodesState(initialNodes)
  const [edges, setEdges, onEdgesChange] = useEdgesState(initialEdges)

  useEffect(() => setNodes(initialNodes), [initialNodes, setNodes])
  useEffect(() => setEdges(initialEdges), [initialEdges, setEdges])

  const onConnect: OnConnect = (params: Edge | Connection) => {
    if (!params.source || !params.target) return
    addRelationship(params.source, params.target, '+')
  }

  return (
    <div className="h-full w-full">
      <ReactFlow
        nodes={nodes}
        edges={edges}
        onNodesChange={onNodesChange}
        onEdgesChange={onEdgesChange}
        onConnect={onConnect}
        onNodeClick={(_, node) => selectVariable(node.id)}
        onEdgeClick={(_, edge) => selectRelationship(edge.id)}
        onPaneClick={() => {
          selectVariable(undefined)
          selectRelationship(undefined)
        }}
        onNodeDragStop={(_, node) => updateVariablePosition(node.id, node.position.x, node.position.y)}
        fitView
      >
        <Background />
        <Controls />
      </ReactFlow>
    </div>
  )
}
```

