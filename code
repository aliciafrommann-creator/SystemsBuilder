### `lib/variable-check.ts`

```ts
import { VariableQuality } from '@/types/system'

const vagueTerms = [
  'qualität',
  'erfolg',
  'problem',
  'schlecht',
  'gut',
  'klarheit',
  'kommunikation',
  'effizienz',
  'workshopqualität',
]

const eventHints = [
  'workshop durchgeführt',
  'meeting',
  'entscheidung getroffen',
  'launch',
  'kickoff',
  'termin',
]

export function qualifyVariable(label: string): { quality: VariableQuality; reason: string } {
  const normalized = label.trim().toLowerCase()

  if (!normalized) {
    return { quality: 'invalid', reason: 'Empty label.' }
  }

  if (eventHints.some((term) => normalized.includes(term))) {
    return {
      quality: 'invalid',
      reason: 'Looks like an event, not a variable. Rephrase it as something that can increase or decrease.',
    }
  }

  if (vagueTerms.some((term) => normalized === term || normalized.includes(term))) {
    return {
      quality: 'needs_refinement',
      reason: 'Likely too vague or too aggregated. Add an observable indicator or split it into more precise variables.',
    }
  }

  return {
    quality: 'good',
    reason: 'Looks usable as a variable. Check whether it can be observed or operationalized.',
  }
}
