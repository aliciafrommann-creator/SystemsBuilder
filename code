### `components/relationship-inspector.tsx`

```tsx
'use client'

import { useMemo } from 'react'
import { useModelStore } from '@/store/model-store'
import { evaluateRelationship } from '@/lib/relationship-check'

const delayOptions = ['none', 'short', 'medium', 'long', 'custom'] as const
const evidenceOptions = ['observed', 'assumed', 'weak_signal'] as const

export function RelationshipInspector() {
  const relationships = useModelStore((s) => s.relationships)
  const variables = useModelStore((s) => s.variables)
  const selectedRelationshipId = useModelStore((s) => s.selectedRelationshipId)
  const updateRelationship = useModelStore((s) => s.updateRelationship)

  const relationship = relationships.find((r) => r.id === selectedRelationshipId)
  const evaluation = useMemo(() => {
    if (!relationship) return null
    return evaluateRelationship(relationship, variables)
  }, [relationship, variables])

  if (!relationship) {
    return (
      <div className="border-l border-zinc-200 bg-white p-4">
        <h2 className="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-600">Relationship Inspector</h2>
        <p className="text-sm text-zinc-500">Select a relationship to inspect it.</p>
      </div>
    )
  }

  return (
    <div className="border-l border-zinc-200 bg-white p-4">
      <h2 className="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-600">Relationship Inspector</h2>

      <div className="space-y-4">
        <div>
          <label className="mb-1 block text-xs text-zinc-500">Polarity</label>
          <select
            value={relationship.polarity}
            onChange={(e) => updateRelationship(relationship.id, { polarity: e.target.value as '+' | '-' })}
            className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm"
          >
            <option value="+">+</option>
            <option value="-">-</option>
          </select>
        </div>

        <div>
          <label className="mb-1 block text-xs text-zinc-500">Delay type</label>
          <select
            value={relationship.delayType ?? 'none'}
            onChange={(e) => updateRelationship(relationship.id, { delayType: e.target.value as any })}
            className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm"
          >
            {delayOptions.map((option) => (
              <option key={option} value={option}>
                {option}
              </option>
            ))}
          </select>
        </div>

        <div>
          <label className="mb-1 block text-xs text-zinc-500">Evidence level</label>
          <select
            value={relationship.evidenceLevel ?? 'assumed'}
            onChange={(e) => updateRelationship(relationship.id, { evidenceLevel: e.target.value as any })}
            className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm"
          >
            {evidenceOptions.map((option) => (
              <option key={option} value={option}>
                {option}
              </option>
            ))}
          </select>
        </div>

        <div>
          <label className="mb-1 block text-xs text-zinc-500">Rationale</label>
          <textarea
            value={relationship.rationale ?? ''}
            onChange={(e) => updateRelationship(relationship.id, { rationale: e.target.value })}
            className="min-h-[100px] w-full rounded-md border border-zinc-300 px-3 py-2 text-sm"
          />
        </div>

        <div>
          <label className="mb-1 block text-xs text-zinc-500">Possible intermediate variable</label>
          <input
            value={relationship.possibleIntermediateVariable ?? ''}
            onChange={(e) => updateRelationship(relationship.id, { possibleIntermediateVariable: e.target.value })}
            className="w-full rounded-md border border-zinc-300 px-3 py-2 text-sm"
          />
        </div>

        {evaluation && (
          <div className="rounded-lg border border-zinc-200 bg-zinc-50 p-3">
            <p className="mb-1 text-xs uppercase tracking-wide text-zinc-500">Relationship quality</p>
            <p className="text-sm font-medium">{evaluation.status}</p>
            <ul className="mt-2 space-y-1 text-sm text-zinc-600">
              {evaluation.messages.map((message, index) => (
                <li key={index}>• {message}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  )
}
